{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@/convex/*": [
        "../../convex/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  }
}